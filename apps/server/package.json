{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@google-cloud/storage": "^7.19.0",
    "@hono/node-server": "^1.19.12",
    "@my-better-t-app/db": "*",
    "@my-better-t-app/env": "*",
    "@vercel/blob": "^2.3.3",
    "dotenv": "^17.2.2",
    "hono": "^4.8.2",
    "openai": "^6.33.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@my-better-t-app/config": "*",
    "@types/bun": "^1.3.4",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
